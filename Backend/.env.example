# PostgreSQL (recommended)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/gcc

# SQLite fallback (omit DATABASE_URL or use):
# DATABASE_URL=sqlite:///data/app.db

# DB-backed scan performance (screeners read stock_prices_daily only)
SCAN_MAX_WORKERS_DB=30
SCAN_PROGRESS_INTERVAL=15

# PostgreSQL connection pool (avoid timeouts during scans + API traffic)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=60

# StockRelay / Goldium iOS feed
STOCKRELAY_URL=https://srelay.onrender.com/api/v1/ingest
STOCKRELAY_ENABLED=true

# Upstox Analytics token (read-only, 1y validity) - https://account.upstox.com/developer/apps
UPSTOX_ANALYTICS_TOKEN=
